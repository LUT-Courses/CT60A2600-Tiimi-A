# Projektin nimi
PROJECT_NAME           = "CT60A2600-TIIMI-A"

# Dokumentaation tallennuspaikka
OUTPUT_DIRECTORY       = doc

# Lähdekoodi
INPUT                  = src
FILE_PATTERNS          = *.c *.h
RECURSIVE              = YES

# Dokumentaatiomuodot
GENERATE_HTML          = YES
GENERATE_LATEX         = YES
GENERATE_XML           = NO

# HTML doc/html/ kansioon, LaTeX väliaikaiseen kansioon
HTML_OUTPUT            = html
LATEX_OUTPUT           = ../doc_latex_tmp

# Kommenttien käsittely
JAVADOC_AUTOBRIEF      = YES
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
STRIP_CODE_COMMENTS    = YES

# Näytetään vain dokumentoidut osat
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_METHODS  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

# Poistetaan tyhjät erikoissivut
GENERATE_TODOLIST      = NO
GENERATE_TESTLIST      = NO
GENERATE_BUGLIST       = NO
GENERATE_DEPRECATEDLIST = NO
SHOW_NAMESPACES        = NO

# Ei lähdekoodia dokumentaatiossa
SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCES_LINK_SOURCE = NO
VERBATIM_HEADERS       = NO

# Kaaviot
HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Polut
FULL_PATH_NAMES        = NO

# LaTeX / PDF asetukset
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES
LATEX_HIDE_INDICES     = YES
COMPACT_LATEX          = YES

# Estetään ylimääräiset kansiot
CREATE_SUBDIRS         = NO

# Varoitukset
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES