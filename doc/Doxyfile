# Projektin nimi
PROJECT_NAME           = "CT60A2600-TIIMI-A"

# Dokumentaation tallennuspaikka
OUTPUT_DIRECTORY       = doc

# Lähdekoodi
INPUT                  = src
FILE_PATTERNS          = *.c *.h
RECURSIVE              = YES

# Dokumentaatiomuodot
GENERATE_HTML          = YES
GENERATE_LATEX         = YES
GENERATE_XML           = NO

# HTML suoraan doc/ juureen, LaTeX väliaikaiseen kansioon
HTML_OUTPUT            = .
LATEX_OUTPUT           = ../doc_latex_tmp

# Kommenttien käsittely
JAVADOC_AUTOBRIEF      = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_METHODS  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = NO
STRIP_CODE_COMMENTS    = YES

# Lähdekoodi dokumentaatiossa
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# Kaaviot
HAVE_DOT               = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = NO

# Polut
FULL_PATH_NAMES        = NO

# Lyhyt kuvaus
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO

# LaTeX / PDF asetukset
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = NO
LATEX_HIDE_INDICES     = YES

# Estetään ylimääräiset kansiot
CREATE_SUBDIRS         = NO